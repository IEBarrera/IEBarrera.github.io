source "https://rubygems.org"

# Jekyll moderno para desarrollo local (compatible con Ruby 4.x).
gem "jekyll", "~> 4.3"

# Liquid 4.0.4+ elimina el viejo 'taint' que Ruby ya no soporta.
gem "liquid", ">= 4.0.4"

# Gemas que salieron de la biblioteca estándar de Ruby en 3.4+ / 4.0
# pero que Jekyll y sus dependencias siguen necesitando.
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
gem "webrick"        # necesario para 'jekyll serve'

# Compatibilidad de zona horaria en Windows.
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
